# KAMA Energy Platform — environment variables
# Copy to .env.dev for local development

# Database
DATABASE_URL=postgresql+asyncpg://kama:kama_dev@localhost:5432/kama_energy

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TELEMETRY=telemetry.raw
KAFKA_GROUP_ID=kama-ingestor

# Auth (Keycloak)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=kama
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256

# ENTSO-E Transparency Platform
# Register at: https://transparency.entsoe.eu → User settings → Security token
ENTSOE_SECURITY_TOKEN=your-entsoe-api-token-here
ENTSOE_AREA_EIC=10YCH-SWISSGRIDC

# InfluxDB 2.x (grid telemetry — 2-year retention)
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=kama_dev_token
INFLUX_ORG=kama
INFLUX_BUCKET=grid_switzerland

# App
DEBUG=true

# ─── E-Mail Postfächer (Hostinger) ────────────────────────────────────────────
# Server: IMAP imap.hostinger.com:993 (SSL) | SMTP smtp.hostinger.com:465 (SSL)

# Sales-Lead-Agent (KAMA-27) — verkauf@kama-power.com
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=verkauf@kama-power.com
SMTP_PASSWORD=<verkauf-password>
SMTP_FROM=verkauf@kama-power.com
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993
IMAP_USER=verkauf@kama-power.com
IMAP_PASSWORD=<verkauf-password>

# Communication-Agent / Verwaltung (KAMA-28) — verwaltung@kama-power.com
# SMTP_USER=verwaltung@kama-power.com
# SMTP_PASSWORD=<verwaltung-password>
# SMTP_FROM=verwaltung@kama-power.com
# IMAP_USER=verwaltung@kama-power.com
# IMAP_PASSWORD=<verwaltung-password>

# Project-Workflow-Engine (KAMA-28) — betrieb@kama-power.com
# SMTP_USER=betrieb@kama-power.com
# SMTP_PASSWORD=<betrieb-password>
# SMTP_FROM=betrieb@kama-power.com
# IMAP_USER=betrieb@kama-power.com
# IMAP_PASSWORD=<betrieb-password>

# Designer / Marketing-Modul — marketing@kama-power.com
# SMTP_USER=marketing@kama-power.com
