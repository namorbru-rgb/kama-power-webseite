# KAMA Energy Platform — environment variables
# Copy to .env.dev for local development

# Database
DATABASE_URL=postgresql+asyncpg://kama:kama_dev@localhost:5432/kama_energy

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TELEMETRY=telemetry.raw
KAFKA_GROUP_ID=kama-ingestor

# Auth (Keycloak)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=kama
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256

# ENTSO-E Transparency Platform
# Register at: https://transparency.entsoe.eu → User settings → Security token
ENTSOE_SECURITY_TOKEN=your-entsoe-api-token-here
ENTSOE_AREA_EIC=10YCH-SWISSGRIDC

# InfluxDB 2.x (grid telemetry — 2-year retention)
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=kama_dev_token
INFLUX_ORG=kama
INFLUX_BUCKET=grid_switzerland

# App
DEBUG=true

# ─── E-Mail Postfächer (Hostinger) ────────────────────────────────────────────
# Server: IMAP imap.hostinger.com:993 (SSL) | SMTP smtp.hostinger.com:465 (SSL)

# Sales-Lead-Agent (KAMA-27) — verkauf@kama-power.com
SALES_SMTP_HOST=smtp.hostinger.com
SALES_SMTP_PORT=465
SALES_SMTP_USER=verkauf@kama-power.com
SALES_SMTP_PASSWORD=<verkauf-password>
SALES_SMTP_FROM=verkauf@kama-power.com
SALES_IMAP_HOST=imap.hostinger.com
SALES_IMAP_PORT=993
SALES_IMAP_USER=verkauf@kama-power.com
SALES_IMAP_PASSWORD=<verkauf-password>

# Communication-Agent / Verwaltung (KAMA-28) — verwaltung@kama-power.com
COMM_SMTP_HOST=smtp.hostinger.com
COMM_SMTP_PORT=465
COMM_SMTP_USER=verwaltung@kama-power.com
COMM_SMTP_PASSWORD=<verwaltung-password>
COMM_SMTP_FROM=verwaltung@kama-power.com
COMM_IMAP_HOST=imap.hostinger.com
COMM_IMAP_PORT=993
COMM_IMAP_USER=verwaltung@kama-power.com
COMM_IMAP_PASSWORD=<verwaltung-password>

# Project-Workflow-Engine (KAMA-28) — betrieb@kama-power.com
WORKFLOW_SMTP_HOST=smtp.hostinger.com
WORKFLOW_SMTP_PORT=465
WORKFLOW_SMTP_USER=betrieb@kama-power.com
WORKFLOW_SMTP_PASSWORD=<betrieb-password>
WORKFLOW_SMTP_FROM=betrieb@kama-power.com
WORKFLOW_IMAP_HOST=imap.hostinger.com
WORKFLOW_IMAP_PORT=993
WORKFLOW_IMAP_USER=betrieb@kama-power.com
WORKFLOW_IMAP_PASSWORD=<betrieb-password>

# Designer / Marketing-Modul — marketing@kama-power.com
MARKETING_SMTP_HOST=smtp.hostinger.com
MARKETING_SMTP_PORT=465
MARKETING_SMTP_USER=marketing@kama-power.com
MARKETING_SMTP_PASSWORD=<marketing-password>
MARKETING_SMTP_FROM=marketing@kama-power.com
MARKETING_IMAP_HOST=imap.hostinger.com
MARKETING_IMAP_PORT=993
MARKETING_IMAP_USER=marketing@kama-power.com
MARKETING_IMAP_PASSWORD=<marketing-password>

# ─── KAMA-net / Supabase ─────────────────────────────────────────────────────
# Supabase project URL (shared across all services)
KAMA_NET_URL=https://nixakeaiibzhesdwtelw.supabase.co

# Anon (public read-only) key — safe to use in API server and frontend paths
# Never grants write access. Set via Supabase Dashboard → Settings → API
KAMA_NET_API_KEY=<supabase-anon-key>
# Also aliased as SUPABASE_ANON_KEY for apps/api
SUPABASE_ANON_KEY=<supabase-anon-key>

# Service-Role key — WRITE access, NEVER expose to browser or commit to repo
# Used ONLY by project-workflow-engine agent-memory store (server-side only)
# Rotate via: Supabase Dashboard → Settings → API → Regenerate service_role secret
# After rotation: update this value and restart project-workflow-engine only
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# Set to "true" only after confirming agent_memory_items/agent_memory_events tables exist
AGENT_MEMORY_ENABLED=false

# ─── Landingpage kama-power.ch (apps/landingpage) ────────────────────────────
# Webhook-URL für Kontaktformular-Leads → KAMA-net
NEXT_PUBLIC_WEBHOOK_URL=https://your-kama-net-webhook-url/leads
