# KAMA Energy Platform — environment variables
# Copy to .env.dev for local development

# Database
DATABASE_URL=postgresql+asyncpg://kama:kama_dev@localhost:5432/kama_energy

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TELEMETRY=telemetry.raw
KAFKA_GROUP_ID=kama-ingestor

# Auth (Keycloak)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=kama
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256

# ENTSO-E Transparency Platform
# Register at: https://transparency.entsoe.eu → User settings → Security token
ENTSOE_SECURITY_TOKEN=your-entsoe-api-token-here
ENTSOE_AREA_EIC=10YCH-SWISSGRIDC

# InfluxDB 2.x (grid telemetry — 2-year retention)
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=kama_dev_token
INFLUX_ORG=kama
INFLUX_BUCKET=grid_switzerland

# App
DEBUG=true
